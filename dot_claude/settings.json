{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(~/Developer/**)",
      "Edit(~/Developer/**)",
      "Write(~/Developer/**)",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -r*)",
      "Bash(rm -R*)",
      "Bash(rm -fr*)",
      "Bash(rm -fR*)",
      "Bash(rm --recursive*)"
    ]
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  }
}
