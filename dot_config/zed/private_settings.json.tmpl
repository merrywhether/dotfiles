// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "right",
  },
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "git_panel": {
    "dock": "right",
  },
  "context_servers": {
{{- if eq .context "personal" }}
    "mcp-server-playwright": {
      "enabled": false,
      "remote": false,
      "settings": {
        "executable_path": "/Applications/Google Chrome Beta.app/Contents/MacOS/Google Chrome Beta",
        "browser": "chromium",
      },
    },
    "mcp-server-figma": {
      "enabled": false,
      "remote": false,
      "settings": {
        "figma_api_key": "{{ keyring "chezmoi" "figma_api_key" }}",
      },
    },
{{- end }}
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "agent": {
    "dock": "left",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
    },
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "claude-sonnet-4.6",
        "enable_thinking": false,
      },
      {
        "provider": "anthropic",
        "model": "claude-opus-4-6-1m-context-latest",
        "enable_thinking": false,
      },
    ],
    "model_parameters": [],
    "tool_permissions": {
      "default": "allow",
      "tools": {
        "terminal": {
          "default": "allow",
          "always_confirm": [
            { "pattern": "sudo\\s+" },
            { "pattern": "\\brm\\s+-[a-z]*r" },
          ],
        },
      },
    },
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "show_edit_predictions": true,

  "languages": {
    "JavaScript": {
      "formatter": ["prettier", { "code_action": "source.fixAll.eslint" }],
    },
    "TypeScript": {
      "formatter": ["prettier", { "code_action": "source.fixAll.eslint" }],
    },
    "Vue.js": {
      "formatter": ["prettier", { "code_action": "source.fixAll.eslint" }],
    },
    "TSX": {
      "formatter": ["prettier", { "code_action": "source.fixAll.eslint" }],
    },
  },

  "ui_font_family": "Comic Code Ligatures",
  "ui_font_size": 16.0,
  "buffer_font_family": "Comic Code Ligatures",
  "buffer_font_size": 16,
  "agent_buffer_font_size": 16,
  "colorize_brackets": true,
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Frappé",
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
}
