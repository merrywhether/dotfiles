# chezmoi templating https://pkg.go.dev/text/template
{{- if eq .context "twitch" }}
# Kiro CLI pre block. Keep at the top of this file.
[[ -f "${HOME}/Library/Application Support/kiro-cli/shell/zshrc.pre.zsh" ]] && builtin source "${HOME}/Library/Application Support/kiro-cli/shell/zshrc.pre.zsh"
{{- end }}

# History
export HISTSIZE=1000000000
export SAVEHIST=$HISTSIZE
setopt EXTENDED_HISTORY HIST_IGNORE_DUPS HIST_IGNORE_SPACE autocd

# Completions
autoload -U compinit; compinit

export PNPM_HOME="$HOME/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

{{- if eq .chezmoi.hostname "stokeProM3" }}
# LM Studio
export PATH="$PATH:$HOME/.lmstudio/bin"
{{- end }}

export VISUAL="zed --wait"
export EDITOR="zed --wait"
export PAGER="bat --plain"
export DO_NOT_TRACK=1

alias pn=pnpm

alias gaa="git add -A"
alias gcm="git commit -m"
alias gco="git checkout"
alias gcob="git checkout -b"
alias gcan="git commit --amend --no-edit"
alias grh="git reset --hard"

source <(fzf --zsh)
ZSH_AUTOSUGGEST_STRATEGY=(history completion)
source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
eval "$(mise activate zsh)"
eval "$(starship init zsh)"

{{- if eq .context "twitch" }}
export PATH=$PATH:$HOME/.toolbox/bin

export TWITCH_ANDROID_HOME=$HOME/Developer/twitch-android
export ANDROID_HOME=$HOME/Library/Android/sdk
export PATH=$PATH:$ANDROID_HOME/emulator
export PATH=$PATH:$ANDROID_HOME/platform-tools
export PATH=$PATH:$ANDROID_HOME/cmdline-tools/latest/bin
export PATH=$PATH:$ANDROID_HOME/tools
export PATH=$PATH:$ANDROID_HOME/tools/bin

export JAVA_HOME=/Applications/Android\ Studio.app/Contents/jbr/Contents/Home/
source $HOME/.brazil_completion/zsh_completion

# Kiro CLI post block. Keep at the bottom of this file.
[[ -f "${HOME}/Library/Application Support/kiro-cli/shell/zshrc.post.zsh" ]] && builtin source "${HOME}/Library/Application Support/kiro-cli/shell/zshrc.post.zsh"
{{- end }}
